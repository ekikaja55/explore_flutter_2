rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Izinkan user yang login untuk akses datanya sendiri
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Izinkan akses ke sub-collection todos milik user tersebut
      match /todos/{todoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}